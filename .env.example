# Copy this file to .env and fill in your values.
# For Vercel: add these as Environment Variables in the project settings.

# Your Anthropic API key — enables live search and the AI assistant.
VITE_ANTHROPIC_KEY=sk-ant-...

# Access password — users must enter this to reach the app.
# Leave blank (or remove) to make the app openly accessible.
VITE_PASSWORD=your-password-here
